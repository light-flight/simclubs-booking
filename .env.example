NODE_ENV=development
LOG_LEVEL=info

# Telegram
TELEGRAM_BOT_TOKEN=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_FALLBACK_MODEL=gpt-5.5

# Postgres
DATABASE_URL=postgres://simclubs:simclubs@localhost:5432/simclubs_booking

# 32-byte base64 key. Generate with: openssl rand -base64 32
SESSION_ENCRYPTION_KEY=

# dry-run prevents any real booking actions. Use playwright only after selector work is complete.
BOOKING_EXECUTOR=dry-run

# Browser
HEADLESS=true
SIMCLUBS_BOOKING_URL=https://simclubs.ru/booking
